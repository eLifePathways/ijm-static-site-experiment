---
import ArticleFigure from './ArticleFigure.astro';
import BodyNode from './BodyNode.astro';
import { resolveFigureImage } from '@/utils/images';

// eslint-disable-next-line @typescript-eslint/no-explicit-any
type AnyNode = Record<string, any>;

interface Props {
  node: AnyNode;
  depth?: number;
  articleId: string;
  // Position among top-level (depth 2) sections — only the first one starts
  // expanded, matching the legacy site's collapsing behaviour.
  index?: number;
}

const { node, depth = 2, articleId, index } = Astro.props;
const type: string = node.type ?? '';
const headingLevel = Math.min(depth, 6) as 2 | 3 | 4 | 5 | 6;
const HeadingTag = `h${headingLevel}` as const;
const isCollapsibleSection = type === 'section' && depth === 2 && !!node.title;

// Pre-cast children arrays in frontmatter to avoid TS generics in template
const sectionChildren: AnyNode[] = type === 'section' || (!type && node.content) ? node.content ?? [] : [];
const listItems: AnyNode[][] = type === 'list' ? node.items ?? [] : [];
const boxChildren: AnyNode[] = type === 'box' ? node.content ?? [] : [];
const quoteParas: Array<{ text: string; type: string }> = type === 'quote' ? node.text ?? [] : [];

const resolvedImage =
  type === 'image' && node.image?.source?.filename
    ? await resolveFigureImage(articleId, node.image.source.filename)
    : null;
if (type === 'image' && !resolvedImage) {
  throw new Error(
    `No source TIFF found for ${articleId}/${node.image?.source?.filename} — expected it at ` +
      `src/generated-tiffs/${articleId}/ (run "npm run prepare-assets").`,
  );
}
---

{/* Top-level section — collapsible, matching the legacy site (only the
    first section after the abstract starts expanded) */}
{isCollapsibleSection && (
  <details id={node.id || undefined} class="article-section article-section--collapsible" open={index === 0}>
    <summary><HeadingTag set:html={node.title} /></summary>
    <div class="article-section__body">
      {sectionChildren.map((child) => (
        <BodyNode node={child} depth={depth + 1} articleId={articleId} />
      ))}
    </div>
  </details>
)}

{/* Section */}
{!isCollapsibleSection && (type === 'section' || (!type && sectionChildren.length > 0)) && (
  <section id={node.id || undefined} class="article-section">
    {node.title && <HeadingTag set:html={node.title} />}
    {sectionChildren.map((child) => (
      <BodyNode node={child} depth={depth + 1} articleId={articleId} />
    ))}
  </section>
)}

{/* Paragraph */}
{type === 'paragraph' && <p set:html={node.text} />}

{/* Figure (image or table assets) */}
{type === 'figure' && (
  <ArticleFigure assets={node.assets} articleId={articleId} />
)}

{/* Single image node */}
{type === 'image' && resolvedImage && (
  <figure id={node.id || undefined}>
    <a
      href={resolvedImage.src}
      class="figure-lightbox-trigger"
      data-pswp-width={resolvedImage.width}
      data-pswp-height={resolvedImage.height}
      target="_blank"
      rel="noreferrer"
    >
      <img
        src={resolvedImage.src}
        width={resolvedImage.width}
        height={resolvedImage.height}
        alt={node.image?.alt ?? ''}
        loading="lazy"
      />
    </a>
    {(node.label || node.title) && (
      <figcaption>
        {node.label && <strong>{node.label}.</strong>}
        {node.title && <span set:html={` ${node.title}`} />}
      </figcaption>
    )}
  </figure>
)}

{/* Table node (bare HTML) */}
{type === 'table' && (
  <div class="table-wrap">
    <Fragment set:html={node.tables?.[0] ?? ''} />
  </div>
)}

{/* List */}
{type === 'list' && (
  <>
    {node.prefix === 'number'
      ? (
        <ol>
          {listItems.map((item) => (
            <li>
              {item.map((child) => (
                <BodyNode node={child} depth={depth} articleId={articleId} />
              ))}
            </li>
          ))}
        </ol>
      ) : (
        <ul>
          {listItems.map((item) => (
            <li>
              {item.map((child) => (
                <BodyNode node={child} depth={depth} articleId={articleId} />
              ))}
            </li>
          ))}
        </ul>
      )
    }
  </>
)}

{/* MathML equation */}
{type === 'mathml' && (
  <div id={node.id || undefined} class="equation">
    {node.label && <span class="equation-label">{node.label}</span>}
    <Fragment set:html={node.mathml} />
  </div>
)}

{/* Box (algorithm, callout, etc.) */}
{type === 'box' && (
  <aside id={node.id || undefined} class="article-box">
    {(node.label || node.title) && (
      <h4 class="article-box__title">
        {node.label && <span class="article-box__label">{node.label}. </span>}
        {node.title && <span set:html={node.title} />}
      </h4>
    )}
    {boxChildren.map((child) => (
      <BodyNode node={child} depth={depth} articleId={articleId} />
    ))}
  </aside>
)}

{/* Code block */}
{type === 'code' && (
  <pre><code>{node.code as string}</code></pre>
)}

{/* Block quote */}
{type === 'quote' && (
  <blockquote>
    {quoteParas.map((p) => <p set:html={p.text} />)}
  </blockquote>
)}

<style>
  blockquote {
    margin: 0 0 var(--space-s);
    padding-inline-start: var(--space-s);
    border-inline-start: 3px solid var(--color-border);
    font-style: italic;
    color: var(--color-ink-muted);
  }

  pre {
    margin: 0 0 var(--space-s);
    padding: var(--space-s);
    background: var(--color-surface-subtle);
    border-radius: 3px;
    overflow-x: auto;

    code {
      font-family: var(--font-mono);
      font-size: var(--step--1);
    }
  }

  .article-box {
    margin: 0 0 var(--space-m);
    padding: var(--space-s) var(--space-m);
    background: var(--color-surface-subtle);
    border-inline-start: 3px solid var(--color-accent);

    .article-box__title {
      margin-block-end: var(--space-2xs);
    }
    .article-box__label {
      color: var(--color-accent);
    }
  }

  .equation {
    margin: 0 0 var(--space-m);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-s);
    overflow-x: auto;

    .equation-label {
      margin-inline-start: auto;
      color: var(--color-ink-muted);
      font-family: var(--font-heading);
      font-size: var(--step--1);
    }
  }

  figure {
    margin: 0 0 var(--space-m);

    img {
      margin-inline: auto;
    }
  }

  .figure-lightbox-trigger {
    display: block;
    cursor: zoom-in;
  }

  figcaption {
    font-family: var(--font-heading);
    font-size: var(--step--1);
    color: var(--color-ink-muted);
    margin-block-start: var(--space-2xs);
  }

  .table-wrap {
    overflow-x: auto;
    margin: 0 0 var(--space-m);

    table {
      border-collapse: collapse;
      width: 100%;
    }
    th,
    td {
      border: 1px solid var(--color-border);
      padding: var(--space-2xs) var(--space-xs);
      text-align: start;
    }
    th {
      font-family: var(--font-heading);
      background: var(--color-surface-subtle);
    }
  }
  .table-footnote {
    font-size: var(--step--1);
    color: var(--color-ink-muted);
  }
</style>
