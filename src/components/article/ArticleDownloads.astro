---
interface Props {
  articleId: string;
  pdfPath: string | null;
}

const { articleId, pdfPath } = Astro.props;
---

<nav class="article-downloads" aria-label="Downloads">
  <ul>
    {pdfPath && (
      <li><a href={pdfPath} id="downloads">Download PDF</a></li>
    )}
    <li><a href={`/articles/${articleId}.bib`}>Download BibTeX</a></li>
    <li><a href={`/articles/${articleId}.ris`}>Download RIS</a></li>
  </ul>
</nav>

<style>
  .article-downloads ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    list-style: none;
    margin: 0 0 var(--space-m);
    padding: 0;
    font-family: var(--font-heading);
    font-weight: bold;
    font-size: var(--step--1);

    a {
      display: inline-block;
      color: var(--color-accent-ink);
      background: var(--color-accent);
      text-decoration: none;
      padding: var(--space-2xs) var(--space-s);
      border-radius: 3px;
    }
    a:hover {
      background: var(--color-accent-strong);
    }
  }
</style>
