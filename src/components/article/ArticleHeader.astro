---
import { getCollection } from 'astro:content';
import { articleTypeLabel, issueSlug } from '@/utils/slugs';
import { resolvePdfPath, formatAuthorList, formatCiteAsAuthors, uniqueAffiliations } from '@/utils/articleContent';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const {
  id,
  type,
  title,
  authorLine,
  doi,
  volume,
  issue,
  fpage,
  lpage,
  published,
  subjects,
  abstract,
  authors,
  pdf,
} = article.data;

const typeLabel = articleTypeLabel(type);
const pdfPath = pdf ? resolvePdfPath(pdf) : null;

const issueId = `${volume}-${issue}`;
const matchedIssue = (await getCollection('issues')).find((i) => i.data.id === issueId);
const issuePath = matchedIssue ? `/collections/${issueId}/${issueSlug(matchedIssue.data.title)}` : null;
const issueTitle = matchedIssue?.data.title ?? `Volume ${volume}`;
const year = published ? new Date(published).getFullYear() : null;
const authorsFormatted = authors ? formatAuthorList(authors) : authorLine ?? null;
const citeAsAuthors = authors ? formatCiteAsAuthors(authors) : authorLine ?? null;
const institutions = authors ? uniqueAffiliations(authors) : [];

// Abstract may be an object with content array or a simple string
const abstractParagraphs: Array<{ text: string }> = (() => {
  if (!abstract) return [];
  if (typeof abstract === 'string') return [{ text: abstract }];
  const a = abstract as { content?: Array<{ text?: string; type?: string }> };
  return (a.content ?? []).filter((n) => n.type === 'paragraph' && n.text) as Array<{ text: string }>;
})();
---

<header class="article-header">
  <div class="article-header__intro">
    {subjects && subjects.length > 0 && (
      <p class="article-header__subjects">
        {subjects.map((s: { id: string; name: string }, i: number) => (
          <>
            <a href={`/subjects/${s.id}`}>{s.name}</a>{i < subjects.length - 1 ? ', ' : ''}
          </>
        ))}
      </p>
    )}

    <p class="article-header__type">
      <a href={`/articles/${type}`}>{typeLabel}</a>
      {year && <span class="article-header__date"> · {year}</span>}
    </p>

    <h1 class="article-header__title" set:html={title} />

    {authorsFormatted && (
      <p class="article-header__authors">{authorsFormatted}</p>
    )}

    {institutions.length > 0 && (
      <p class="article-header__institutions">{institutions.join('; ')}</p>
    )}

    <p class="article-header__volume">
      {issuePath ? <a href={issuePath}>{issueTitle}</a> : issueTitle}
    </p>
  </div>

  {citeAsAuthors && (
    <p class="article-header__cite">
      <span class="article-header__cite_label">Cite as:</span>
      {' '}{citeAsAuthors}; {year}; <span set:html={title} />; International Journal of Microsimulation; {volume}({issue}); {fpage}–{lpage}.
      {' '}<span class="article-header__cite_doi">doi: <a href={`https://doi.org/${doi}`}>{doi}</a></span>
    </p>
  )}

  {abstractParagraphs.length > 0 && (
    <section id="abstract" class="article-section article-header__abstract">
      <h2>Abstract</h2>
      {abstractParagraphs.map((p) => <p set:html={p.text} />)}
    </section>
  )}

  <nav class="article-header__downloads" aria-label="Downloads">
    <ul>
      {pdfPath && (
        <li><a href={pdfPath} id="downloads">Download PDF</a></li>
      )}
      <li><a href={`/articles/${id}.bib`}>Download BibTeX</a></li>
      <li><a href={`/articles/${id}.ris`}>Download RIS</a></li>
    </ul>
  </nav>
</header>

<style>
  .article-header__intro {
    text-align: center;
    max-width: 46rem;
    margin-inline: auto;
    padding-block-end: var(--space-m);
    border-block-end: 1px solid var(--color-border);
  }

  .article-header__subjects {
    font-family: var(--font-heading);
    font-size: var(--step--2);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 var(--space-2xs);

    a {
      color: inherit;
      text-decoration: none;
    }
    a:hover {
      color: var(--color-accent-strong);
    }
  }

  .article-header__type {
    font-family: var(--font-heading);
    font-size: var(--step--2);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-2xs);

    a {
      color: var(--color-accent);
      text-decoration: none;
    }
  }

  .article-header__title {
    margin-block-end: var(--space-xs);
  }

  .article-header__authors {
    font-family: var(--font-heading);
    font-size: var(--step-1);
    margin: 0 0 var(--space-2xs);
  }

  .article-header__institutions {
    font-family: var(--font-heading);
    font-size: var(--step--1);
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-2xs);
  }

  .article-header__volume {
    font-family: var(--font-heading);
    font-size: var(--step--1);
    color: var(--color-ink-muted);
    margin: 0;

    a {
      color: inherit;
    }
  }

  .article-header__abstract {
    margin-block: var(--space-m);
  }

  .article-header__downloads ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    list-style: none;
    margin: 0 0 var(--space-m);
    padding: 0;
    font-family: var(--font-heading);
    font-weight: bold;
    font-size: var(--step--1);

    a {
      display: inline-block;
      color: var(--color-accent-ink);
      background: var(--color-accent);
      text-decoration: none;
      padding: var(--space-2xs) var(--space-s);
      border-radius: 3px;
    }
    a:hover {
      background: var(--color-accent-strong);
    }
  }

</style>

<style>
  .article-header__cite {
    font-family: var(--font-heading);
    font-size: var(--step--2);
    letter-spacing: 0.02em;
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    text-align: center;
    margin: 0 0 var(--space-m);
    padding-block: var(--space-xs);
    border-block-end: 1px solid var(--color-border);
  }

  .article-header__cite_label {
    text-transform: uppercase;
    font-weight: bold;
  }

  .article-header__cite_doi {
    display: inline-block;

    a {
      color: inherit;
    }
  }
</style>
