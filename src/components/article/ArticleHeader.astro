---
import { getCollection } from 'astro:content';
import { articleTypeLabel, issueSlug } from '@/utils/slugs';
import { resolvePdfPath, formatAuthorList } from '@/utils/articleContent';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const {
  id,
  type,
  title,
  authorLine,
  doi,
  volume,
  issue,
  fpage,
  lpage,
  published,
  subjects,
  abstract,
  authors,
  pdf,
  copyright,
} = article.data;

const typeLabel = articleTypeLabel(type);
const pdfPath = pdf ? resolvePdfPath(pdf) : null;

const issueId = `${volume}-${issue}`;
const matchedIssue = (await getCollection('issues')).find((i) => i.data.id === issueId);
const issuePath = matchedIssue ? `/collections/${issueId}/${issueSlug(matchedIssue.data.title)}` : null;
const year = published ? new Date(published).getFullYear() : null;
const authorsFormatted = authors ? formatAuthorList(authors) : authorLine ?? null;

// Abstract may be an object with content array or a simple string
const abstractParagraphs: Array<{ text: string }> = (() => {
  if (!abstract) return [];
  if (typeof abstract === 'string') return [{ text: abstract }];
  const a = abstract as { content?: Array<{ text?: string; type?: string }> };
  return (a.content ?? []).filter((n) => n.type === 'paragraph' && n.text) as Array<{ text: string }>;
})();
---

<header class="article-header">
  <p class="article-header__type">
    <a href={`/articles/${type}`}>{typeLabel}</a>
  </p>

  <h1 class="article-header__title" set:html={title} />

  {authorsFormatted && (
    <p class="article-header__authors">{authorsFormatted}</p>
  )}

  <dl class="article-header__meta">
    <dt>Published</dt>
    <dd>{year}</dd>
    <dt>Volume</dt>
    <dd>{issuePath ? <a href={issuePath}>Volume {volume}</a> : `Volume ${volume}`}</dd>
    <dt>Issue</dt>
    <dd>{issue}</dd>
    {(fpage || lpage) && <dt>Pages</dt>}
    {(fpage || lpage) && <dd>{fpage}–{lpage}</dd>}
    <dt>DOI</dt>
    <dd>
      <a href={`https://doi.org/${doi}`} target="_blank" rel="noopener">{doi}</a>
    </dd>
  </dl>

  {subjects && subjects.length > 0 && (
    <ul class="article-header__subjects">
      {subjects.map((s: { id: string; name: string }) => (
        <li><a href={`/subjects/${s.id}`}>{s.name}</a></li>
      ))}
    </ul>
  )}

  {abstractParagraphs.length > 0 && (
    <section id="abstract" class="article-section article-header__abstract">
      <h2>Abstract</h2>
      {abstractParagraphs.map((p) => <p set:html={p.text} />)}
    </section>
  )}

  <nav class="article-header__downloads" aria-label="Downloads">
    <ul>
      {pdfPath && (
        <li><a href={pdfPath} id="downloads">Download PDF</a></li>
      )}
      <li><a href={`/articles/${id}.bib`}>Download BibTeX</a></li>
      <li><a href={`/articles/${id}.ris`}>Download RIS</a></li>
    </ul>
  </nav>

  {copyright && (
    <p class="article-header__copyright" set:html={copyright.statement} />
  )}
</header>

<style>
  .article-header__type {
    font-family: var(--font-heading);
    font-size: var(--step--2);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin: 0 0 var(--space-2xs);

    a {
      color: var(--color-accent);
      text-decoration: none;
    }
  }

  .article-header__title {
    margin-block-end: var(--space-xs);
  }

  .article-header__authors {
    font-family: var(--font-heading);
    font-size: var(--step-1);
    margin: 0 0 var(--space-s);
  }

  .article-header__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    column-gap: var(--space-3xs);
    row-gap: var(--space-2xs);
    font-family: var(--font-heading);
    margin: 0 0 var(--space-s);
    padding-block: var(--space-xs);
    border-block: 1px solid var(--color-border);

    dt {
      font-size: var(--step--2);
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: var(--color-ink-muted);
    }
    dt::after {
      content: ':';
    }
    dd {
      margin-inline-end: var(--space-m);
    }
  }

  .article-header__subjects {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs) var(--space-s);
    list-style: none;
    margin: 0 0 var(--space-m);
    padding: 0;
    font-family: var(--font-heading);
    font-size: var(--step--1);

    a {
      color: var(--color-accent);
      text-decoration: none;
    }
    a:hover {
      color: var(--color-accent-strong);
    }
  }

  .article-header__abstract {
    margin-block-end: var(--space-m);
  }

  .article-header__downloads ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    list-style: none;
    margin: 0 0 var(--space-m);
    padding: 0;
    font-family: var(--font-heading);
    font-weight: bold;
    font-size: var(--step--1);

    a {
      display: inline-block;
      color: var(--color-accent-ink);
      background: var(--color-accent);
      text-decoration: none;
      padding: var(--space-2xs) var(--space-s);
      border-radius: 3px;
    }
    a:hover {
      background: var(--color-accent-strong);
    }
  }

  .article-header__copyright {
    font-size: var(--step--1);
    color: var(--color-ink-muted);
  }
</style>
