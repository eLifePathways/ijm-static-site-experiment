---
interface TocItem {
  id: string;
  title: string;
}

interface Props {
  items: TocItem[];
  // Present only on articles that have a "Figures and data" view — when set,
  // renders the legacy site's Article/Figures and data toggle above the jump
  // list. Both pages pass their own hrefs/items; there's no client-side tab
  // switching, just two full-page views sharing this component.
  articleHref?: string;
  figuresHref?: string;
  activeView?: 'article' | 'figures';
}

const { items, articleHref, figuresHref, activeView = 'article' } = Astro.props;
---

{/* A single wrapper element keeps this as one grid item in the article
    page's 3-column layout — Astro doesn't wrap multiple top-level template
    nodes, so two conditional root elements here would become two separate
    grid children and break the column placement. */}
<div class="article-sidebar">
  {figuresHref && articleHref && (
    <nav class="view-tabs" aria-label="Article view">
      <a
        href={articleHref}
        class:list={['view-tabs__link', { 'view-tabs__link--active': activeView === 'article' }]}
        aria-current={activeView === 'article' ? 'page' : undefined}
      >Article</a>
      <a
        href={figuresHref}
        class:list={['view-tabs__link', { 'view-tabs__link--active': activeView === 'figures' }]}
        aria-current={activeView === 'figures' ? 'page' : undefined}
      >Figures and data</a>
    </nav>
  )}

  {items.length > 0 && (
    <details class="article-toc">
      <summary>Jump to</summary>
      <ul>
        {items.map((item) => (
          <li><a href={`#${item.id}`} set:html={item.title} /></li>
        ))}
      </ul>
    </details>
  )}
</div>

<style>
  @media (min-width: 75em) {
    .article-sidebar {
      position: sticky;
      top: var(--space-m);
    }
  }

  /* Same typographic treatment as .article-toc's "Jump to" summary below —
     plain text links, not a pill/tab control, so the two view links and the
     ToC toggle read as one consistent list of sidebar labels. */
  .view-tabs {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    margin-block-end: var(--space-m);
  }
  .view-tabs__link {
    font-family: var(--font-heading);
    font-weight: bold;
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-decoration: none;
    color: var(--color-ink-muted);
  }
  .view-tabs__link:hover {
    color: var(--color-accent);
  }
  .view-tabs__link--active {
    color: var(--color-ink);
  }
  .view-tabs__link--active:hover {
    color: var(--color-ink);
    cursor: default;
  }

  .article-toc {
    margin-block-end: var(--space-m);

    > summary {
      cursor: pointer;
      list-style: none;
      display: flex;
      align-items: center;
      gap: var(--space-2xs);
      font-family: var(--font-heading);
      font-weight: bold;
      font-size: var(--step--1);
      text-transform: uppercase;
      letter-spacing: 0.03em;
      color: var(--color-ink-muted);

      &::-webkit-details-marker {
        display: none;
      }
      &::before {
        content: '';
        flex: none;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 4px 0 4px 6px;
        border-color: transparent transparent transparent var(--color-ink-muted);
        transition: transform 0.15s ease;
      }
    }
    &[open] > summary::before {
      transform: rotate(90deg);
    }

    ul {
      list-style: none;
      margin: var(--space-2xs) 0 0;
      padding: 0;
    }
    li {
      margin: 0 0 var(--space-2xs);
    }
    a {
      font-family: var(--font-heading);
      font-size: var(--step--1);
      text-decoration: none;
      color: var(--color-ink-muted);
    }
    a:hover {
      color: var(--color-accent);
    }
  }

</style>
