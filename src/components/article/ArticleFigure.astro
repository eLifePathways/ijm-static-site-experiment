---
interface ImageAsset {
  type: 'image';
  id: string;
  label?: string;
  title?: string;
  image: {
    alt: string;
    source: { filename: string };
    size?: { width: number; height: number };
  };
}

interface TableAsset {
  type: 'table';
  id: string;
  label?: string;
  title?: string;
  tables: string[];
  footnotes?: Array<{ text: Array<{ text: string; type: string }> }>;
}

type Asset = ImageAsset | TableAsset;

interface Props {
  assets: Asset[];
  articleId: string;
}

const { assets, articleId } = Astro.props;

function imgSrc(filename: string) {
  return `/images/${articleId}/${filename}`;
}
---

{assets.map((asset) => (
  <figure id={asset.id}>
    {asset.type === 'image' && (
      <img
        src={imgSrc(asset.image.source.filename)}
        alt={asset.image.alt || ''}
        width={asset.image.size?.width}
        height={asset.image.size?.height}
        loading="lazy"
      />
    )}
    {asset.type === 'table' && (
      <div class="table-wrap">
        <Fragment set:html={asset.tables[0]} />
        {asset.footnotes?.map((fn) =>
          fn.text.map((p) => <p class="table-footnote" set:html={p.text} />)
        )}
      </div>
    )}
    {(asset.label || asset.title) && (
      <figcaption>
        {asset.label && <strong>{asset.label}.</strong>}
        {asset.title && <span set:html={` ${asset.title}`} />}
      </figcaption>
    )}
  </figure>
))}

<style>
  figure {
    margin: 0 0 var(--space-m);

    img {
      margin-inline: auto;
    }
  }
  figcaption {
    font-family: var(--font-heading);
    font-size: var(--step--1);
    color: var(--color-ink-muted);
    margin-block-start: var(--space-2xs);
  }

  .table-wrap {
    overflow-x: auto;
    margin: 0 0 var(--space-m);

    table {
      border-collapse: collapse;
      width: 100%;
    }
    th,
    td {
      border: 1px solid var(--color-border);
      padding: var(--space-2xs) var(--space-xs);
      text-align: start;
    }
    th {
      font-family: var(--font-heading);
      background: var(--color-surface-subtle);
    }
  }
  .table-footnote {
    font-size: var(--step--1);
    color: var(--color-ink-muted);
  }
</style>
