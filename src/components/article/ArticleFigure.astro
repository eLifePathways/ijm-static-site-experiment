---
import { resolveFigureImage } from '@/utils/images';

interface ImageAsset {
  type: 'image';
  id: string;
  label?: string;
  title?: string;
  image: {
    alt: string;
    source: { filename: string };
  };
}

interface TableAsset {
  type: 'table';
  id: string;
  label?: string;
  title?: string;
  tables: string[];
  footnotes?: Array<{ text: Array<{ text: string; type: string }> }>;
}

type Asset = ImageAsset | TableAsset;

interface Props {
  assets: Asset[];
  articleId: string;
}

const { assets, articleId } = Astro.props;

const resolvedImages = new Map<string, Awaited<ReturnType<typeof resolveFigureImage>>>();
for (const asset of assets) {
  if (asset.type === 'image') {
    const resolved = await resolveFigureImage(articleId, asset.image.source.filename);
    if (!resolved) {
      throw new Error(
        `No source TIFF found for ${articleId}/${asset.image.source.filename} — expected it at ` +
          `src/generated-tiffs/${articleId}/ (run "npm run prepare-assets").`,
      );
    }
    resolvedImages.set(asset.id, resolved);
  }
}
---

{assets.map((asset) => (
  <figure id={asset.id}>
    {asset.type === 'image' && (() => {
      const resolved = resolvedImages.get(asset.id)!;
      return (
        <a
          href={resolved.src}
          class="figure-lightbox-trigger"
          data-pswp-width={resolved.width}
          data-pswp-height={resolved.height}
          target="_blank"
          rel="noreferrer"
        >
          <img src={resolved.src} alt={asset.image.alt || ''} width={resolved.width} height={resolved.height} loading="lazy" />
        </a>
      );
    })()}
    {asset.type === 'table' && (
      <div class="table-wrap">
        <Fragment set:html={asset.tables[0]} />
        {asset.footnotes?.map((fn) =>
          fn.text.map((p) => <p class="table-footnote" set:html={p.text} />)
        )}
      </div>
    )}
    {(asset.label || asset.title) && (
      <figcaption>
        {asset.label && <strong>{asset.label}.</strong>}
        {asset.title && <span set:html={` ${asset.title}`} />}
      </figcaption>
    )}
  </figure>
))}

<style>
  figure {
    margin: 0 0 var(--space-m);

    img {
      margin-inline: auto;
    }
  }
  figcaption {
    font-family: var(--font-heading);
    font-size: var(--step--1);
    color: var(--color-ink-muted);
    margin-block-start: var(--space-2xs);
  }

  .figure-lightbox-trigger {
    display: block;
    cursor: zoom-in;
  }

  .table-wrap {
    overflow-x: auto;
    margin: 0 0 var(--space-m);

    table {
      border-collapse: collapse;
      width: 100%;
    }
    th,
    td {
      border: 1px solid var(--color-border);
      padding: var(--space-2xs) var(--space-xs);
      text-align: start;
    }
    th {
      font-family: var(--font-heading);
      background: var(--color-surface-subtle);
    }
  }
  .table-footnote {
    font-size: var(--step--1);
    color: var(--color-ink-muted);
  }
</style>
