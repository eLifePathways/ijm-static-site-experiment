---
import CategoryItems from '@/components/CategoryItems.astro';

interface Item {
  label: string;
  href: string;
}
interface Props {
  heading: string;
  items: Item[];
  columns?: number;
}
const { heading, items, columns = 3 } = Astro.props;
---

<section class="category-list wrapper">
  {/* Mobile: collapsed by default, matching the legacy site's behaviour of
      showing just a toggle link until opened. Native <details>, no JS.
      Desktop: a plain heading + list, always visible — CSS can reliably
      *hide* the <details> version at that breakpoint, but reliably forcing
      a closed <details> open past the browser's own collapse animation
      isn't consistently possible, so this renders both and lets a media
      query pick one rather than fight that. */}
  <details class="category-list__toggle">
    <summary>{heading}</summary>
    <CategoryItems items={items} columns={columns} />
  </details>
  <div class="category-list__static">
    <h3>{heading}</h3>
    <CategoryItems items={items} columns={columns} />
  </div>
</section>

<style>
  .category-list {
    border-bottom: 1px solid var(--color-border);
    padding-block-end: var(--space-m);
    margin-block-end: var(--space-m);
  }

  summary,
  h3 {
    font-family: var(--font-heading);
    font-weight: bold;
    font-size: var(--step-2);
  }

  summary {
    cursor: pointer;
    padding-block: var(--space-2xs);
  }

  h3 {
    margin: 0 0 var(--space-xs);
  }

  .category-list__static {
    display: none;
  }

  @media (min-width: 45.625em) {
    .category-list__toggle {
      display: none;
    }
    .category-list__static {
      display: block;
    }
  }
</style>
