---
import { getCollection } from 'astro:content';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const entries = (await getCollection('about'))
  .filter((entry) => entry.data.order !== undefined)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const slugToPath: Record<string, string> = {
  'aims-and-scope': '/about',
  'editorial-board': '/about/editorial-board',
  'editorial-policy': '/about/editorial-policy',
  'reviewer-notes': '/about/reviewer-notes',
  'call-for-papers': '/about/call-for-papers',
};
---

<nav aria-label="About sections" class="about-menu wrapper">
  <h2>About sections</h2>
  <ul>
    {entries.map((entry) => {
      const href = slugToPath[entry.id] ?? `/about/${entry.id}`;
      return (
        <li>
          <a href={href} aria-current={href === currentPath ? 'page' : undefined}>
            {entry.data.title}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<style>
  .about-menu {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-m) var(--space-l);

    h2 {
      font-size: var(--step-1);
      margin-block-end: var(--space-xs);
    }

    ul {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2xs) var(--space-m);
      list-style: none;
      margin: 0;
      padding: 0;
    }

    a {
      color: var(--color-accent);
      text-decoration: none;
      font-family: var(--font-heading);
      font-size: var(--step--1);
    }
    a:hover {
      color: var(--color-accent-strong);
    }
    a[aria-current='page'] {
      color: var(--color-ink);
      font-weight: bold;
      text-decoration: underline;
    }
  }
</style>
