---
import { getCollection } from 'astro:content';
import { issueSlug } from '@/utils/slugs';

const issues = await getCollection('issues');
const withYear = issues.map((issue) => ({
  issue,
  year: new Date(issue.data.published).getUTCFullYear(),
}));

const years = withYear.map((i) => i.year);
const maxYear = Math.max(...years);
const minYear = Math.min(...years);

// 3-year bands counting down from the newest year with content. The last
// band may be shorter than 3 years if the data doesn't divide evenly —
// simpler than the legacy site's fixed-width last band (which leaves a
// year uncovered by any label when it doesn't divide evenly either).
const bands: Array<{ start: number; end: number; issues: typeof withYear }> = [];
for (let top = maxYear; top >= minYear; top -= 3) {
  const bottom = Math.max(top - 2, minYear);
  bands.push({
    start: top,
    end: bottom,
    issues: withYear
      .filter((i) => i.year >= bottom && i.year <= top)
      .sort((a, b) => b.issue.data.published.localeCompare(a.issue.data.published)),
  });
}
---

<aside class="issues-group">
  <h3>Issues group</h3>
  {bands.map((band) => (
    <details>
      <summary>{band.start === band.end ? band.start : `${band.start}-${band.end}`}</summary>
      <ol>
        {band.issues.map(({ issue }) => (
          <li>
            <a href={`/collections/${issue.data.id}/${issueSlug(issue.data.title)}`}>
              {issue.data.title}
            </a>
          </li>
        ))}
      </ol>
    </details>
  ))}
  <a href="/collections" class="issues-group__more">See more issues »</a>
</aside>

<style>
  .issues-group {
    h3 {
      font-size: var(--step-1);
      margin-block-end: var(--space-xs);
    }

    details {
      border-top: 1px solid var(--color-border);
    }
    details:last-of-type {
      border-bottom: 1px solid var(--color-border);
    }

    summary {
      font-family: var(--font-heading);
      font-weight: bold;
      font-size: var(--step-2);
      cursor: pointer;
      padding-block: var(--space-2xs);
    }

    ol {
      list-style: none;
      margin: 0;
      padding: 0 0 var(--space-s);
    }
    li {
      margin: 0 0 var(--space-2xs);
    }
    a {
      font-size: var(--step--1);
      color: var(--color-ink);
      text-decoration: none;
    }
    a:hover {
      color: var(--color-accent);
    }
  }

  .issues-group__more {
    display: inline-block;
    margin-block-start: var(--space-s);
    font-family: var(--font-heading);
    font-weight: bold;
    font-size: var(--step--1);
    color: var(--color-accent);
    text-decoration: none;
  }
  .issues-group__more:hover {
    color: var(--color-accent-strong);
  }
</style>
