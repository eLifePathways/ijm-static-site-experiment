---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<header class="hero">
  <h1 class="hero__title">{title}</h1>
</header>

<style>
  .hero {
    /* dark gradient keeps the title readable regardless of which part of
       the (fairly light) map graphic lands behind it at a given viewport */
    background-image: linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)), url('/header.jpg');
    background-size: cover;
    background-position: center;
    min-height: clamp(14rem, 11.5652rem + 12.1739vw, 21rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: var(--space-m);
  }

  .hero__title {
    color: var(--color-surface);
    font-size: var(--step-6);
    text-align: center;
    text-wrap: balance;
    margin: 0;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  }
</style>
