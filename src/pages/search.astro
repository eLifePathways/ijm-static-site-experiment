---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@pagefind/default-ui/css/ui.css';
---

<BaseLayout title="Search">
  <main id="maincontent" class="wrapper">
    <h1>Search</h1>
    <div id="search"></div>
  </main>
</BaseLayout>

<script>
  import { PagefindUI } from '@pagefind/default-ui';

  // @pagefind/default-ui ships no type declarations, so triggerSearch (which
  // does exist at runtime per https://pagefind.app/docs/ui-usage/) is typed
  // by hand here.
  interface PagefindUIInstance {
    triggerSearch: (term: string) => void;
  }

  window.addEventListener('DOMContentLoaded', () => {
    const search = new PagefindUI({
      element: '#search',
      showSubResults: true,
      openFilters: ['Research category'],
    }) as unknown as PagefindUIInstance;

    const q = new URLSearchParams(window.location.search).get('q');
    if (q) search.triggerSearch(q);
  });
</script>

<style>
  #search {
    /* Ties Pagefind's own themeable custom properties to our tokens
       instead of leaving its defaults, so the search UI doesn't look like
       a bolted-on widget. */
    --pagefind-ui-primary: var(--color-ink);
    --pagefind-ui-text: var(--color-ink);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-surface-subtle);
    --pagefind-ui-font: var(--font-body);
  }
</style>
