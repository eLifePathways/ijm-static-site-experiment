---
import { getAllArticles } from '@/utils/content';
import { type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleHeader from '@/components/article/ArticleHeader.astro';
import ArticleInfo from '@/components/article/ArticleInfo.astro';
import ArticleToc from '@/components/article/ArticleToc.astro';
import BodyNode from '@/components/article/BodyNode.astro';
import ReferenceList from '@/components/article/ReferenceList.astro';
import 'photoswipe/style.css';

export async function getStaticPaths() {
  const articles = await getAllArticles();
  return articles.map((article) => ({
    params: { id: article.data.id },
    props: { article },
  }));
}

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { id, title, body, references, appendices } = article.data;

// eslint-disable-next-line @typescript-eslint/no-explicit-any
type AnyNode = Record<string, any>;
const bodyNodes = body as AnyNode[];
const appendixNodes = (appendices ?? []) as AnyNode[];
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const refs = (references ?? []) as any[];

const tocItems = [
  { id: 'abstract', title: 'Abstract' },
  ...bodyNodes
    .filter((node) => node.type === 'section' && node.title && node.id)
    .map((node) => ({ id: node.id as string, title: node.title as string })),
  ...appendixNodes
    .filter((node) => node.title && node.id)
    .map((node) => ({ id: node.id as string, title: node.title as string })),
  ...(refs.length > 0 ? [{ id: 'references', title: 'References' }] : []),
  { id: 'info', title: 'Article and author information' },
];
---

<BaseLayout title={title}>
  <main
    id="maincontent"
    class="article-page wrapper"
    data-pagefind-body
    data-pagefind-meta={`url:/articles/${id}`}
  >
    <ArticleHeader article={article} />

    <div class="article-content-grid">
      <ArticleToc items={tocItems} />

      <div class="article-content">
        <div class="article-body">
          {bodyNodes.map((node, index) => (
            <BodyNode node={node} depth={2} articleId={id} index={index} />
          ))}
        </div>

        {appendixNodes.map((node) => (
          <BodyNode node={node} depth={2} articleId={id} />
        ))}

        {refs.length > 0 && (
          <ReferenceList references={refs} />
        )}

        <ArticleInfo article={article} />
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @media (min-width: 75em) {
    .article-content-grid {
      display: grid;
      /* Mirrors the legacy site's 2/8/2-twelfths split: the ToC fills the
         left margin and an equal-width empty column on the right keeps the
         content column itself centered rather than flush against the ToC. */
      grid-template-columns: 12rem 1fr 12rem;
      gap: var(--space-l);
      align-items: start;
    }
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  window.addEventListener('DOMContentLoaded', () => {
    const lightbox = new PhotoSwipeLightbox({
      gallery: '.article-page',
      children: 'a.figure-lightbox-trigger',
      bgOpacity: 1,
      pswpModule: () => import('photoswipe'),
    });
    lightbox.init();
  });
</script>
