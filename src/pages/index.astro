---
import { getAllArticles, getAllSubjects } from '@/utils/content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import CategoryList from '@/components/CategoryList.astro';
import ArticleTeaser from '@/components/ArticleTeaser.astro';
import IssuesGroupSidebar from '@/components/IssuesGroupSidebar.astro';
import Pagination from '@/components/Pagination.astro';

const subjects = (await getAllSubjects()).sort((a, b) => a.data.name.localeCompare(b.data.name));
const subjectItems = subjects.map((s) => ({ label: s.data.name, href: `/subjects/${s.data.id}` }));

// The legacy site links these to "book-reviews"/"data-watch"/etc., which
// are dead routes there too (confirmed: 404 in the live app) — pointing
// straight at the real article-type pages instead.
const exploreItems = [
  { label: 'Book reviews', href: '/articles/scientific-correspondence' },
  { label: 'Data watch', href: '/articles/tools-resources' },
  { label: 'Research notes', href: '/articles/short-report' },
  { label: 'Software reviews', href: '/articles/registered-report' },
];

// Matches the legacy PHP HomeController's forType(...) filter for "Latest
// research" — editorials (and corrections) are excluded from this listing.
const RESEARCH_TYPES = new Set([
  'research-article',
  'research-communication',
  'registered-report',
  'scientific-correspondence',
  'short-report',
  'tools-resources',
  'feature',
]);

const allArticles = await getAllArticles();
const allLatest = allArticles
  .filter((article) => RESEARCH_TYPES.has(article.data.type))
  // Same-day ties can't be broken identically to the legacy site: its API sorts
  // by a full timestamp, but this dataset only records publish dates (day
  // granularity), so tie order among same-day articles is a best-effort
  // approximation, not a guaranteed match.
  .sort(
    (a, b) =>
      b.data.published.localeCompare(a.data.published) || a.data.id.localeCompare(b.data.id),
  );
const PAGE_SIZE = 10;
const latestArticles = allLatest.slice(0, PAGE_SIZE);
const lastPage = Math.ceil(allLatest.length / PAGE_SIZE);
---

<BaseLayout title="Latest research">
  <Hero title="International Journal of Microsimulation" />
  <main id="maincontent">
    <p class="lead-para wrapper">
      The International Journal of Microsimulation (IJM) is the official online peer-reviewed
      journal of the International Microsimulation Association
    </p>
    <CategoryList heading="Research categories" items={subjectItems} columns={3} />
    <CategoryList
      heading="In addition to standard research articles, explore our:"
      items={exploreItems}
      columns={2}
    />
    <div class="wrapper home-grid">
      <div class="home-grid__main">
        <h2>Latest research</h2>
        <ol class="teaser-list">
          {latestArticles.map((article) => <ArticleTeaser article={article} />)}
        </ol>
        <Pagination currentPage={1} lastPage={lastPage} nextHref={lastPage > 1 ? '/page/2' : undefined} />
      </div>
      <IssuesGroupSidebar />
    </div>
  </main>
</BaseLayout>

<style>
  .lead-para {
    font-family: var(--font-heading);
    font-weight: normal;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-xs);
    margin-block-end: var(--space-xs);
  }

  .home-grid {
    display: grid;
    gap: var(--space-l);
  }

  @media (min-width: 60em) {
    .home-grid {
      grid-template-columns: 2fr 1fr;
      align-items: start;
    }
  }
</style>
