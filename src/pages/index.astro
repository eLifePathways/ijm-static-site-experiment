---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';

// Matches the legacy PHP HomeController's forType(...) filter for "Latest
// research" — editorials (and corrections) are excluded from this listing.
const RESEARCH_TYPES = new Set([
  'research-article',
  'research-communication',
  'registered-report',
  'scientific-correspondence',
  'short-report',
  'tools-resources',
  'feature',
]);

const allArticles = await getCollection('articles');
const latestArticles = allArticles
  .filter((article) => RESEARCH_TYPES.has(article.data.type))
  // Same-day ties can't be broken identically to the legacy site: its API sorts
  // by a full timestamp, but this dataset only records publish dates (day
  // granularity), so tie order among same-day articles is a best-effort
  // approximation, not a guaranteed match.
  .sort(
    (a, b) =>
      b.data.published.localeCompare(a.data.published) || a.data.id.localeCompare(b.data.id),
  )
  .slice(0, 10);
---

<BaseLayout title="Latest research">
  <Hero title="International Journal of Microsimulation" />
  <main id="maincontent">
    <p class="lead-para wrapper">
      The International Journal of Microsimulation (IJM) is the official online peer-reviewed
      journal of the International Microsimulation Association
    </p>
    <div class="wrapper">
      <h2>Latest research</h2>
      <ul id="listing">
        {latestArticles.map((article) => (
          <li>
            <a href={`/articles/${article.data.id}`} set:html={article.data.title} />
          </li>
        ))}
      </ul>
    </div>
  </main>
</BaseLayout>

<style>
  .lead-para {
    font-family: var(--font-heading);
    font-weight: bold;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-xs);
    margin-block-end: var(--space-m);
  }
</style>
