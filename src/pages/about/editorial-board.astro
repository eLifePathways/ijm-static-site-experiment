---
import { getEntry, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import AboutMenu from '@/components/AboutMenu.astro';

const entry = await getEntry('about', 'editorial-board');
if (!entry) throw new Error('Missing about/editorial-board.md content entry');
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title}>
  <main id="maincontent">
    <h1>{entry.data.title}</h1>
    <Content />
  </main>
  <AboutMenu currentPath="/about/editorial-board" />
</BaseLayout>
