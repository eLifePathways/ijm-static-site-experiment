---
import '@/styles/global.css';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'International Journal of Microsimulation' } = Astro.props;
const siteTitle = 'International Journal of Microsimulation';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title === siteTitle ? title : `${title} | ${siteTitle}`}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    {/* trailingSlash is "never" site-wide; without this, Pagefind derives a
        trailing-slash URL from the crawled file path (dir/index.html) and
        every search result 404s. Pagefind honours this tag over its default. */}
    <link rel="canonical" href={Astro.url.pathname} />
  </head>
  <body>
    <SiteHeader />
    <slot />
    <SiteFooter />
  </body>
</html>
